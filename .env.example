# ============================================================
# testgen 環境變數範本（複製為 .env 使用；.env 已在 .gitignore）
# 全部可留空 — 有預設值或由 agent .md 決定
# ============================================================

# runner：opencode（預設）| qwen（需 npm i -D @qwen-code/sdk）
#UT_RUNNER=opencode

# 模型（留空 = 用 .opencode/agent/*.md 的 model 欄位；格式 provider/model）
#UT_WRITER_MODEL=vllm/qwen3-coder
#UT_REVIEWER_MODEL=anthropic/claude-sonnet-4-6

# 迭代與門檻
#UT_MAX_ITER=5
#UT_MIN_LINE_COV=80
#UT_MIN_BRANCH_COV=70
# 1 = 找不到 JaCoCo 報告時 coverage gate 直接 FAIL
#UT_STRICT_COV=1
# 六維分數門檻局部覆蓋（JSON，0-10 制，預設 7/7/7/6/7/6）
#UT_SCORE_THRESHOLDS={"readability":6}

# 行為開關
#UT_SKIP_REVIEW=1
#UT_QUIET=1
#UT_SKIP_GUARD=1
# 單輪 agent 逾時（毫秒，預設 15 分鐘）
#UT_AGENT_TIMEOUT_MS=900000
# opencode 執行檔路徑（不在 PATH 時）
#UT_OPENCODE_BIN=opencode
# 0 = 不加 --format json（舊版 opencode 不支援 JSONL 事件時的退路）
#UT_OPENCODE_JSON=0
# 1 = writer 附加 --dangerously-skip-permissions（非互動被 permission 擋住寫檔時的最後手段）
#UT_OC_SKIP_PERMS=1

# 路徑覆蓋（UT_SKILL_DIR 未設時：目標 repo .opencode/.claude → 工具內建）
#UT_STANDARDS_PATH=
#UT_SKILL_DIR=
#UT_JACOCO_XML=
# 額外 maven 參數，例如 report 未綁 test phase 時：
#UT_MAVEN_ARGS=jacoco:report

# ---- UT_RUNNER=qwen 才需要（@qwen-code/sdk 走 OpenAI 相容協定）----
#OPENAI_API_KEY=
#OPENAI_BASE_URL=
